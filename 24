def log(message: str):
    now = datetime.now().strftime("%H:%M:%S")
    print(f"\033[92m[{now}]\033[0m {message}")
    sys.stdout.flush()


def random_string(length: int = 100) -> str:
    chars = string.ascii_letters + string.digits
    return ''.join(random.choices(chars, k=length))


def handle_signal(signum, frame):
    global RUNNING
    log(f"Received signal {signum}. Shutting down...")
    RUNNING = False


def main():
    signal.signal(signal.SIGINT, handle_signal)
    signal.signal(signal.SIGTERM, handle_signal)

    folder = "MunnaTheDev"
    os.makedirs(folder, exist_ok=True)

    banner()
    log("File I/O Demonstration Started")

    while RUNNING:
        try:
            file_name = os.path.join(
                folder,
                f"{random_string(8)}.txt"
            )

            # Create file
            with open(file_name, "w") as f:
                for _ in range(random.randint(10, 100)):
                    f.write(random_string() + "\n")

            log(f"Created: {file_name}")
            time.sleep(2)

            # Edit file
            with open(file_name, "w") as f:
                for _ in range(random.randint(10, 100)):
                    f.write(random_string() + "\n")

            log(f"Edited: {file_name}")
            time.sleep(1)

            # Delete file
            os.remove(file_name)
            log(f"Deleted: {file_name}")
            time.sleep(1)

        except Exception as e:
            log(f"Error: {e}")
            time.sleep(5)

    log("Exited cleanly.")


if __name__ == "__main__":
    main()
